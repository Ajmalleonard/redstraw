{
  "name": "redstraw-vscode-icons",
  "displayName": "RedStraw Icons",
  "description": "File icon theme for RedStraw — adds icons for redstraw.config.* files and the .redstraw output folder",
  "version": "1.1.0",
  "publisher": "redstraw",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ajmalleonard/redstraw"
  },
  "homepage": "https://github.com/ajmalleonard/redstraw",
  "bugs": {
    "url": "https://github.com/ajmalleonard/redstraw/issues"
  },
  "keywords": [
    "redstraw",
    "icons",
    "file-icons",
    "icon-theme",
    "content-management",
    "nextjs",
    "vite"
  ],
  "categories": ["Themes"],
  "engines": {
    "vscode": "^1.80.0"
  },
  "icon": "icons/icon.png",
  "galleryBanner": {
    "color": "#0f0f1a",
    "theme": "dark"
  },
  "contributes": {
    "iconThemes": [
      {
        "id": "redstraw",
        "label": "RedStraw Icons",
        "path": "./themes/redstraw-icon-theme.json"
      }
    ]
  },
  "scripts": {
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  }
}
